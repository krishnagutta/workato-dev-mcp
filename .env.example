# Copy to .env and fill in. Or just `export` these in your shell before launching Claude.
# Your personal Workato Developer API token (Workspace admin -> API clients; Recipe operator role is enough).
WORKATO_TOKEN=wrkaus-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — change only for non-US data centers (e.g. https://app.eu.workato.com/api).
WORKATO_API_BASE=https://www.workato.com/api
